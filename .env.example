# 시연용: 이 파일을 .env 로 복사한 뒤 키를 넣으세요. (.env 는 git 에 올라가지 않습니다)
OPENAI_API_KEY=sk-your-key-here
DEMO_MODE=1

# 개인정보 저장·보호자 대시보드
PRIVACY_ENABLED=1
GUARDIAN_PIN=change-me-to-strong-pin
# 선택: Fernet 키 (없으면 GUARDIAN_PIN 기반 파생 키 사용)
# PRIVACY_ENCRYPTION_KEY=
# DATA_DIR=./data
# Vercel/serverless: defaults to /tmp/ai41-privacy (ephemeral)

# 도입·상담 문의 메일 (수신: ai41@ai41.kr)
CONTACT_TO=ai41@ai41.kr
# 방법1) Resend (Vercel 권장): https://resend.com
# RESEND_API_KEY=re_xxx
# 도메인 미인증 시 발신은 onboarding@resend.dev (코드가 자동 폴백)
CONTACT_FROM=AI41 <onboarding@resend.dev>
# ai41.kr 을 https://resend.com/domains 에서 인증한 뒤:
# CONTACT_FROM=AI41 <ai41@ai41.kr>
# RESEND_DOMAIN_VERIFIED=1
# 방법2) SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=app-password
# SMTP_FROM=AI41 <your@gmail.com>
# SMTP_USE_TLS=1

# Neon Postgres (블로그 CMS) — https://console.neon.tech
# DATABASE_URL=postgresql://USER:PASS@HOST/neondb?sslmode=require
ADMIN_PIN=change-me-admin-pin
# ADMIN_TOKEN_SECRET=optional-extra-secret
# 관리 페이지: /admin.html (공개 내비에 노출하지 않음)

# 날씨 기본 도시 (사용자가 「날씨」만 말할 때)
WEATHER_DEFAULT_Q=서울
